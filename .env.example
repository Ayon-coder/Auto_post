# Copy to .env and fill in values.

LINKEDIN_BUFFER_ACCESS_TOKEN=
X_BUFFER_ACCESS_TOKEN=

GRAPHQL_URL=https://api.buffer.com/graphql


# Cloudinary (used for image/video uploads across all platforms)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Backend API base URL the browser will call (must include /api). The server injects this into the dashboard.
# Leave empty: same host as this app (auto: https://your-deployment.vercel.app/api).
# If the dashboard is opened from another origin, set explicitly, e.g. BACKEND_API_BASE_URL=https://api.example.com/api
BACKEND_API_BASE_URL=

# Dashboard Authentication (required)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# Optional: speed / dev
# BUFFER_TOKEN_CACHE_TTL=600
# FLASK_DEBUG=0
# FLASK_USE_RELOADER=1
# PORT=5000
# FLASK_RUN_HOST=127.0.0.1
